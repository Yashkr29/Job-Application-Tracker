# App
ENVIRONMENT=development
APP_NAME="Job Application Tracker"
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# Database
# Supabase PostgreSQL example: postgresql+asyncpg://postgres:<password>@db.<project>.supabase.co:5432/postgres
DATABASE_URL=sqlite+aiosqlite:///./job_tracker.db
TEST_DATABASE_URL=sqlite+aiosqlite:///:memory:

# JWT
JWT_SECRET_KEY=replace-with-a-long-random-secret-at-least-24-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Upstash Redis or local Redis fallback
REDIS_URL=redis://localhost:6379/0
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# SMTP / fastapi-mail
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME="Job Tracker"

# Supabase Storage
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=resumes

